# ---------------------------------------------------------------------------
# 操作系统与编辑器杂项
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# IntelliJ IDEA / JetBrains（个人工作区与本地数据，不提交）
# 若团队需要共享运行配置，可改为只忽略 workspace.xml 等单项
# ---------------------------------------------------------------------------
/.idea/
/eighteen_report/*.iml

# ---------------------------------------------------------------------------
# Gradle / Java 构建产物与缓存（源码目录下的 build 仍被忽略）
# ---------------------------------------------------------------------------
/eighteen_report/.gradle/
/eighteen_report/build/

# ---------------------------------------------------------------------------
# Node.js / 前端（依赖与 Vite 预构建缓存）
# ---------------------------------------------------------------------------
/frontend/node_modules/
/frontend/dist/

# ---------------------------------------------------------------------------
# 日志与本地环境变量（避免密钥入库）
# ---------------------------------------------------------------------------
*.log
logs/
.env
.env.local
.env.*.local
/temp/

# 本地生成的「仅上传服务器」目录与压缩包（见 docker/build-for-server.sh）
/eighteen-report-server-bundle/
/eighteen-report-server-bundle.tar.gz

/.cursor/

# Docker 生成的可执行 jar（仅供镜像 COPY 使用）
/docker/app.jar

/eighteen_report/src/main/resources/static/**
/.aiassistant/
